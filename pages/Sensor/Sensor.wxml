<view class="container {{themeClass}}">
  <view class="card">
    <!-- 控制按钮 -->
    <view class="button-group">
      <button 
        class="control-btn {{isListening ? 'stop-btn' : 'start-btn'}}" 
        bindtap="{{isListening ? 'stopSensorListening' : 'startSensorListening'}}"
      >
        {{isListening ? '停止监听' : '开始监听'}}
      </button>
      <button class="control-btn reset-btn" bindtap="resetData">重置数据</button>
    </view>

    <!-- 加速度计 -->
    <view class="sensor-section">
      <view class="section-title">加速度计</view>
      <view class="axis-grid">
        <view class="axis-card x-axis">
          <view class="axis-label">X轴</view>
          <view class="axis-value">{{xFormatted}}</view>
        </view>
        <view class="axis-card y-axis">
          <view class="axis-label">Y轴</view>
          <view class="axis-value">{{yFormatted}}</view>
        </view>
        <view class="axis-card z-axis">
          <view class="axis-label">Z轴</view>
          <view class="axis-value">{{zFormatted}}</view>
        </view>
      </view>
    </view>

    <!-- 陀螺仪 -->
    <view class="sensor-section">
      <view class="section-title">陀螺仪</view>
      <view class="axis-grid">
        <view class="axis-card x-axis">
          <view class="axis-label">X轴</view>
          <view class="axis-value">{{gxFormatted}}</view>
        </view>
        <view class="axis-card y-axis">
          <view class="axis-label">Y轴</view>
          <view class="axis-value">{{gyFormatted}}</view>
        </view>
        <view class="axis-card z-axis">
          <view class="axis-label">Z轴</view>
          <view class="axis-value">{{gzFormatted}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 状态指示器 -->
  <view class="status-indicator {{isListening ? 'active' : 'inactive'}}">
    <view class="status-dot"></view>
    <text class="status-text">{{isListening ? '监听中' : '已停止'}}</text>
  </view>

  <view class="privacy-notice">
    <view class="notice-icon">🔒</view>
    <view class="notice-text">温馨提示：该小程序所有应用都允许在设备本地处理数据，不会上传至服务器，请放心使用</view>
  </view>
</view>