<view class="container {{themeClass}}">
  <view class="card">
    <view class="game-header">
      <text class="game-title">24点游戏</text>
      <text class="score">得分: {{score}}</text>
    </view>

    <view class="cards-display">
      <view class="card-item" wx:for="{{cards}}" wx:key="index">
        <text class="card-number">{{item}}</text>
      </view>
    </view>

    <view class="expression-display">
      <text class="expression-text">{{expression || '请输入表达式'}}</text>
    </view>

    <view class="input-group">
      <text class="group-title">数字</text>
      <view class="number-buttons">
        <button class="btn number" wx:for="{{cards}}" wx:key="index" 
                data-value="{{item}}" data-index="{{index}}" bindtap="onNumberTap">{{item}}</button>
      </view>
    </view>

    <view class="input-group">
      <text class="group-title">运算符</text>
      <view class="operator-buttons">
        <button class="btn operator" data-value="+" bindtap="onOperatorTap">+</button>
        <button class="btn operator" data-value="-" bindtap="onOperatorTap">-</button>
        <button class="btn operator" data-value="*" bindtap="onOperatorTap">×</button>
        <button class="btn operator" data-value="/" bindtap="onOperatorTap">÷</button>
      </view>
    </view>

    <view class="input-group">
      <text class="group-title">括号</text>
      <view class="bracket-buttons">
        <button class="btn bracket" data-value="(" bindtap="onBracketTap">(</button>
        <button class="btn bracket" data-value=")" bindtap="onBracketTap">)</button>
      </view>
    </view>

    <view class="button-group">
      <button bindtap="onClear">清除</button>
      <button bindtap="onDelete">删除</button>
      <button bindtap="onSubmit" class="submit-btn">提交</button>
      <button bindtap="onNewGame" class="new-game-btn">新游戏</button>
    </view>

    <view class="error" wx:if="{{message}}">{{message}}</view>
  </view>
</view>