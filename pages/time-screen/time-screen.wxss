.container {
  width: 100vw;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #000;
  position: fixed;
  top: 0;
  left: 0;
}

.back-button {
  position: absolute;
  top: 20px;
  left: 20px;
  width: 50px;
  height: 50px;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  background-color: rgba(0, 255, 0, 0.1);
  border: 2px solid #0F0;
  z-index: 100;
  transition: all 0.3s ease;
}

.back-button:active {
  background-color: rgba(0, 255, 0, 0.3);
  transform: scale(0.95);
}

.back-icon {
  color: #0F0;
  font-size: 30px;
  font-weight: bold;
  text-shadow: 0 0 10px #0F0;
}

.time-display {
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.time-text {
  color: #0F0;
  font-size: 15vw;
  font-family: 'Courier New', monospace;
  text-shadow: 0 0 20px #0F0, 0 0 40px #0F0;
  font-weight: bold;
  letter-spacing: 1vw;
  transition: font-size 0.3s ease;
}

/* 横屏样式 - 字体更大 */
@media screen and (orientation: landscape) {
  .time-text {
    font-size: 8vw;
    letter-spacing: 0.5vw;
  }
}

/* 竖屏样式 */
@media screen and (orientation: portrait) {
  .time-text {
    font-size: 15vw;
    letter-spacing: 1vw;
  }
}