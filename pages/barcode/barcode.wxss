.container {
  padding: 25px;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: var(--page-bg);
  min-height: 100vh;
}

.input-section {
  width: 100%;
  max-width: 500px;
  margin-bottom: 30px;
  background: var(--card-bg);
  padding: 20px;
  border-radius: 12px;
  box-shadow: var(--shadow-color);
}

.input-section input {
  width: 100%;
  padding: 15px 15px;
  margin-bottom: 20px;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  font-size: 16px;
  line-height: 1.5;
  transition: border-color 0.3s;
  background-color: var(--content-bg);
  color: var(--text-primary);
  box-sizing: border-box;
  min-height: 50px;
}

.input-section input:focus {
  border-color: #07C160;
  outline: none;
}

.input-hint {
  font-size: 12px;
  color: var(--text-tertiary);
  margin: -10px 0 15px 0;
  padding: 0 5px;
}

.type-selector {
  display: flex;
  align-items: center;
  margin-bottom: 20px;
  gap: 10px;
}

.type-selector text {
  font-size: 16px;
  color: var(--text-primary);
  white-space: nowrap;
}

.picker-display {
  flex: 1;
  padding: 15px 15px;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  background-color: var(--card-bg);
  color: var(--text-primary);
  position: relative;
  text-align: center;
  min-height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.picker-display::after {
  content: "▼";
  position: absolute;
  right: 15px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-tertiary);
  font-size: 12px;
}

button {
  background-color: #07C160;
  color: white;
  border: none;
  border-radius: 8px;
  padding: 12px 0;
  font-size: 16px;
  width: 100%;
  margin-top: 10px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}

.container.dark button {
  background-color: #09e765;
  color: #000;
}

button:active {
  transform: scale(0.98);
}

button::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 5px;
  height: 5px;
  background: rgba(255, 255, 255, 0.5);
  opacity: 0;
  border-radius: 100%;
  transform: scale(1, 1) translate(-50%, -50%);
  transform-origin: 50% 50%;
}

.container.dark button::after {
  background: rgba(0, 0, 0, 0.3);
}

button:focus:not(:active)::after {
  animation: ripple 1s ease-out;
}

@keyframes ripple {
  0% {
    transform: scale(0, 0);
    opacity: 0.5;
  }
  20% {
    transform: scale(25, 25);
    opacity: 0.3;
  }
  100% {
    opacity: 0;
    transform: scale(40, 40);
  }
}

.loading {
  position: relative;
  pointer-events: none;
}

.loading::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  z-index: 1;
}

.loading::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 20px;
  height: 20px;
  margin: -10px 0 0 -10px;
  border: 3px solid rgba(255,255,255,0.3);
  border-radius: 50%;
  border-top-color: white;
  animation: spin 1s ease-in-out infinite;
  z-index: 2;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.barcode-preview {
  margin-top: 30px;
  text-align: center;
  background: var(--card-bg);
  padding: 20px;
  border-radius: 12px;
  box-shadow: var(--shadow-color);
  width: 100%;
  max-width: 500px;
}

.barcode-preview image {
  max-width: 100%;
  height: auto;
  border: 1px solid var(--border-color);
  margin-bottom: 20px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
