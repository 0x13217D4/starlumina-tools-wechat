.container {
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #ffffff;
}

/* 深色模式 */
.container.dark {
  background-color: #1a1a1a;
  color: #e0e0e0;
}

.progress {
  margin-bottom: 30px;
  font-size: 16px;
  color: #666;
}

.container.dark .progress {
  color: #aaa;
}

.question {
  margin-bottom: 30px;
  font-size: 18px;
  text-align: center;
  font-weight: bold;
  color: #333;
}

.container.dark .question {
  color: #e0e0e0;
}

.options button {
  margin-bottom: 15px;
  width: 100%;
  padding: 12px;
  background-color: #f5f5f5;
  border: none;
  border-radius: 5px;
  color: #333;
}

.container.dark .options button {
  background-color: #3a3a3a;
  color: #e0e0e0;
}

.options button:active {
  background-color: #e5e5e5;
}

.container.dark .options button:active {
  background-color: #4a4a4a;
}

.result {
  text-align: center;
  padding: 20px;
  background-color: #f9f9f9;
  border-radius: 10px;
  margin-top: 20px;
  width: 100%;
}

.container.dark .result {
  background-color: #2d2d2d;
}

.result-header {
  margin-bottom: 25px;
}

.result-title {
  font-size: 22px;
  font-weight: bold;
  color: #1aad19;
  margin-bottom: 10px;
}

.container.dark .result-title {
  color: #1aad19;
}

.total-score {
  font-size: 16px;
  color: #333;
  margin-bottom: 15px;
  display: block;
}

.container.dark .total-score {
  color: #e0e0e0;
}

/* 总体指标区域 */
.total-metrics {
  margin: 20px 0;
  padding: 15px;
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.08);
}

.container.dark .total-metrics {
  background-color: #3a3a3a;
  box-shadow: 0 2px 6px rgba(0,0,0,0.3);
}

.metric {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #f0f0f0;
}

.container.dark .metric {
  border-bottom-color: #444;
}

.metric:last-child {
  border-bottom: none;
}

.metric-label {
  font-size: 15px;
  color: #666;
  font-weight: 500;
}

.container.dark .metric-label {
  color: #aaa;
}

.metric-value {
  font-size: 16px;
  color: #1aad19;
  font-weight: bold;
}

.container.dark .metric-value {
  color: #1aad19;
}

/* 区块标题 */
.section-title {
  display: block;
  font-size: 18px;
  font-weight: bold;
  color: #333;
  margin-bottom: 15px;
  padding-left: 10px;
  border-left: 4px solid #1aad19;
}

.container.dark .section-title {
  color: #e0e0e0;
}

/* 各维度得分区域 */
.dimensions {
  margin: 20px 0;
}

.dimension {
  margin-bottom: 15px;
  padding: 12px;
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.08);
}

.container.dark .dimension {
  background-color: #3a3a3a;
  box-shadow: 0 2px 6px rgba(0,0,0,0.3);
}

.dimension-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.dim-name {
  font-size: 15px;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.container.dark .dim-name {
  color: #e0e0e0;
}

.dim-score {
  font-size: 18px;
  font-weight: bold;
  color: #1aad19;
  margin-left: 10px;
}

.container.dark .dim-score {
  color: #1aad19;
}

.dim-description {
  padding: 10px;
  background-color: #f5f9ff;
  border-radius: 6px;
  font-size: 14px;
  line-height: 1.6;
  color: #555;
  text-align: justify;
}

.container.dark .dim-description {
  background-color: #2a3a4a;
  color: #ccc;
}

.description {
  margin: 25px 0;
  padding: 15px;
  background-color: #f0f8ff;
  border-radius: 8px;
  font-size: 15px;
  line-height: 1.6;
  text-align: left;
  color: #333;
}

.container.dark .description {
  background-color: #2a3a4a;
  color: #e0e0e0;
}

.restart-btn {
  margin-top: 20px;
  background-color: #1aad19;
  color: white;
  border: none;
  border-radius: 5px;
  padding: 12px 25px;
  font-size: 16px;
}

.container.dark .restart-btn {
  background-color: #1aad19;
  color: white;
}

.restart-btn:active {
  background-color: #129612;
}