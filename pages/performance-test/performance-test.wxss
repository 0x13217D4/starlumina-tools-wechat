.container {
  padding: 20px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* ?????? */
.info-section {
  background-color: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  color: #333;
  margin-bottom: 15px;
  padding-bottom: 10px;
  border-bottom: 2px solid #f0f0f0;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

.info-item {
  display: flex;
  flex-direction: column;
  padding: 12px;
  background-color: #fafafa;
  border-radius: 8px;
}

.info-label {
  font-size: 13px;
  color: #999;
  margin-bottom: 5px;
}

.info-value {
  font-size: 15px;
  color: #333;
  font-weight: 500;
}

/* ???? */
.test-section {
  background-color: #fff;
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.test-btn {
  width: 100%;
  height: 50px;
  line-height: 50px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 16px;
  font-weight: bold;
  border: none;
  border-radius: 25px;
  margin-bottom: 20px;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
}

.test-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.test-btn.testing {
  background: #b5b5b5;
  box-shadow: none;
}

/* ??? */
.progress-container {
  margin-bottom: 30px;
}

.progress-text {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
  letter-spacing: 2px;
  font-size: 14px;
  color: #666;
}

.progress-percent {
  font-weight: bold;
  color: #1890ff;
}

.progress-hint {
  text-align: center;
  margin-top: 8px;
  font-size: 12px;
  color: #999;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* ???? */
.overall-score {
  text-align: center;
  padding: 25px;
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  border-radius: 12px;
  margin-bottom: 25px;
}

.score-title {
  font-size: 16px;
  color: #666;
  margin-bottom: 10px;
  letter-spacing: 2px;
}

.score-value {
  font-size: 56px;
  font-weight: bold;
  margin-bottom: 10px;
  letter-spacing: 2px;
}

.score-desc {
  font-size: 14px;
  font-weight: 500;
}

/* ?????? */
.scores-grid {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.score-item {
  padding: 15px;
  background-color: #fafafa;
  border-radius: 8px;
}

.score-label {
  font-size: 14px;
  color: #666;
  margin-bottom: 8px;
  display: block;
}

.score-number {
  font-size: 24px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8px;
  display: block;
}

/* ???? */
.note-section {
  background-color: #fff9e6;
  border-radius: 8px;
  padding: 15px;
  border-left: 4px solid #faad14;
}

.note-text {
  font-size: 13px;
  color: #856404;
  line-height: 1.6;
  display: flex;
  align-items: flex-start;
}

.note-icon {
  margin-right: 8px;
  font-size: 14px;
}